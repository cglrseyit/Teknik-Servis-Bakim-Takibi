PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=development

# Frontend URL (e-posta linkleri için)
CLIENT_URL=https://your-domain.com

# SMTP — günlük bakım hatırlatma e-postaları için (boş bırakılırsa e-posta devre dışı)
# Gmail örneği: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=ornek@gmail.com, SMTP_PASS=<app password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Bellis Teknik Servis <noreply@example.com>"
