PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=development

# Frontend URL (e-posta linkleri için)
CLIENT_URL=https://your-domain.com

# SMTP — günlük bakım hatırlatma e-postaları için (boş bırakılırsa e-posta devre dışı)
SMTP_HOST=mail.example.com.tr
SMTP_PORT=587
SMTP_USER=bakim@example.com.tr
SMTP_PASS=your_smtp_password
SMTP_FROM=Teknik Servis <bakim@example.com.tr>
